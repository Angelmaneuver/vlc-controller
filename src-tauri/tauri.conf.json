{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vlc-controller",
  "version": "0.1.1",
  "identifier": "angelmaneuver.vlc.controller",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "vlc-controller",
        "width": 420,
        "height": 39.59,
        "minWidth": 420,
        "maxWidth": 420,
        "minHeight": 39.59,
        "maxHeight": 39.59,
        "resizable": false,
        "decorations": false,
        "hiddenTitle": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "cli": {
      "description": "VLC Webインタフェースの接続情報",
      "args": [
        {
          "name": "url",
          "short": "u",
          "description": "VLC WebインタフェースのURL",
          "takesValue": true
        },
        {
          "name": "password",
          "short": "p",
          "description": "VLC Webインタフェースの認証パスワード",
          "takesValue": true
        }
      ]
    }
  }
}
